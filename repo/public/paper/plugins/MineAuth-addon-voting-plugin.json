{
  "$schema": "https://repo.mpm.nikomaru.dev/schema/plugin-info.json",
  "id": "MineAuth-addon-voting-plugin",
  "source": "https://github.com/morinoparty/MineAuth",
  "repositories": [
    {
      "type": "github",
      "id": "morinoparty/MineAuth",
      "fileNameRegex": "MineAuth-addon-voting-plugin-.*\\.jar$",
      "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)",
      "latest": {
        "versionMatcher": "^v\\d+\\.\\d+\\.\\d+$",
        "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)"
      },
      "beta": {
        "versionMatcher": "^preview-pr\\d+-[a-f0-9]+$"
      }
    }
  ],
  "dependencies": [
    "MineAuth"
  ],
  "softDependencies": [
    "VotingPlugin"
  ],
  "defaultVersion": "sync:MineAuth"
}
