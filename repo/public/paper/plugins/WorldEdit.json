{
  "$schema": "https://repo.mpm.nikomaru.dev/schema/plugin-info/v1.json",
  "id": "WorldEdit",
  "license": "GPL-3.0-only",
  "website": "https://modrinth.com/plugin/worldedit",
  "repositories": [
    {
      "type": "modrinth",
      "id": "1u6JkXh5",
      "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)",
      "latest": {
        "versionMatcher": "^\\d+\\.\\d+\\.\\d+$",
        "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)"
      },
      "beta": {
        "versionMatcher": "-beta",
        "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)-beta-\\d+(?:\\.\\d+)?"
      },
      "alpha": {
        "versionMatcher": "-rc",
        "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)-rc-\\d+"
      }
    }
  ]
}
