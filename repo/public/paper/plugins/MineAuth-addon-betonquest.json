{
  "$schema": "https://repo.mpm.nikomaru.dev/schema/plugin-info/v1.json",
  "id": "MineAuth-addon-betonquest",
  "source": "https://github.com/morinoparty/MineAuth",
  "repositories": [
    {
      "type": "github",
      "id": "morinoparty/MineAuth",
      "fileNameRegex": "MineAuth-addon-betonquest-.*\\.jar$",
      "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)",
      "latest": {
        "useUpstreamLabel": true,
        "versionModifier": "(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)"
      },
      "beta": {
        "useUpstreamLabel": true
      }
    }
  ],
  "dependencies": [
    "MineAuth"
  ],
  "softDependencies": [
    "BetonQuest"
  ],
  "defaultVersion": "sync:MineAuth"
}
